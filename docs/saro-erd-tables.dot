      <TR><TD ALIGN="LEFT" PORT="id" BGCOLOR="white"><FONT POINT-SIZE="11"><B><U>id</U></B>  <FONT POINT-SIZE="9" COLOR="#777">PK</FONT></FONT></TD></TR><TR><TD ALIGN="LEFT" PORT="conversation_id" BGCOLOR="white"><FONT POINT-SIZE="11"><I>conversation_id</I>  <FONT POINT-SIZE="9" COLOR="#777">FK</FONT></FONT></TD></TR><TR><TD ALIGN="LEFT" PORT="sender_id" BGCOLOR="white"><FONT POINT-SIZE="11"><I>sender_id</I>  <FONT POINT-SIZE="9" COLOR="#777">FK</FONT></FONT></TD></TR><TR><TD ALIGN="LEFT" PORT="body" BGCOLOR="white"><FONT POINT-SIZE="11">body</FONT></TD></TR><TR><TD ALIGN="LEFT" PORT="is_read" BGCOLOR="white"><FONT POINT-SIZE="11">is_read</FONT></TD></TR><TR><TD ALIGN="LEFT" PORT="created_at" BGCOLOR="white"><FONT POINT-SIZE="11">created_at</FONT></TD></TR>
